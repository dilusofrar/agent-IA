{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "project1",
  "main": "src/index.ts",
  "compatibility_date": "2026-04-25",
  "observability": {
    "enabled": true
  },
  "vars": {
    "ADMIN_USERNAME": "diegoluks",
    "D1_BINDING_NAME": "D1",
    "ENABLE_API_DOCS": "false",
    "PORT": "8000",
    "PYTHONPATH": "/app/src",
    "R2_BUCKET_NAME": "rendflare",
    "R2_REGION": "auto",
    "R2_ENDPOINT_URL": "https://6984ceb902d1604548a6b113c6f8e780.r2.cloudflarestorage.com",
    "R2_BINDING_NAME": "R2"
  },
  "d1_databases": [
    {
      "binding": "D1",
      "database_name": "agent-ia-ponto",
      "database_id": "738be066-2aed-4043-b050-52c3cd3e12b4"
    }
  ],
  "r2_buckets": [
    {
      "binding": "R2",
      "bucket_name": "rendflare"
    }
  ],
  "containers": [
    {
      "class_name": "AgentIaPontoContainer",
      "image": "../Dockerfile",
      "image_build_context": "..",
      "instance_type": "basic",
      "max_instances": 2
    }
  ],
  "durable_objects": {
    "bindings": [
      {
        "name": "APP_CONTAINER",
        "class_name": "AgentIaPontoContainer"
      }
    ]
  },
  "migrations": [
    {
      "tag": "v1",
      "new_sqlite_classes": [
        "AgentIaPontoContainer"
      ]
    }
  ]
}
